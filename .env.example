# 企微自建应用
WECOM_CORP_ID=wwxxxxxxxxxxxxxxxx
WECOM_AGENT_ID=1000002
WECOM_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 对外 HTTPS 地址（企微 OAuth 回调域、卡片链接、封面图都依赖它）
BASE_URL=https://bless.example.com

# 会话签名密钥（随机字符串，生产环境务必修改）
SESSION_SECRET=please-change-me-to-a-long-random-string

# 服务端口
PORT=8080

# 本地调试：跳过 OAuth，模拟已登录用户
DEV_BYPASS=true
DEV_USERID=zhangsan
DEV_NAME=张三
